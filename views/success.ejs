<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Payment Successful - PayPal QR Demo</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 min-h-screen flex items-center justify-center p-4">
  <div class="max-w-lg w-full text-center fade-in">
    <div class="bg-white rounded-2xl shadow-lg p-8 mb-4">
      <div class="text-6xl mb-4">✅</div>
      <h1 class="text-2xl font-bold text-gray-900 mb-2">Payment Successful!</h1>
      <p class="text-gray-500 mb-2">Your payment has been processed.</p>
      
      <div class="bg-green-50 border border-green-200 rounded-xl p-4 mt-4 text-left">
        <div class="space-y-2 text-sm">
          <div class="flex justify-between">
            <span class="text-gray-500">Order ID</span>
            <span class="font-mono text-xs bg-white px-2 py-0.5 rounded border" id="orderIdDisplay">---</span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-500">Status</span>
            <span class="text-green-600 font-medium">COMPLETED</span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-500">Payer</span>
            <span id="payerDisplay">---</span>
          </div>
          <div class="flex justify-between border-t border-green-200 pt-2 mt-2">
            <span class="font-medium">Amount</span>
            <span class="font-bold text-lg" id="amountDisplay">---</span>
          </div>
        </div>
      </div>

      <div class="mt-6 space-y-3">
        <a href="/" 
           class="inline-block w-full paypal-blue text-white font-semibold py-3 px-6 rounded-lg transition">
          🔲 Generate Another QR Code
        </a>
        <a href="/" 
           class="inline-block w-full bg-gray-100 hover:bg-gray-200 text-gray-700 font-medium py-3 px-6 rounded-lg transition">
          ← Back to Home
        </a>
      </div>
    </div>

    <p class="text-xs text-gray-400">
      PayPal QR Code Demo | Live Orders API
    </p>
  </div>

  <script>
    // Parse token from URL
    const params = new URLSearchParams(window.location.search);
    const token = params.get('token');
    const payerId = params.get('PayerID');
    
    if (token) {
      document.getElementById('orderIdDisplay').textContent = token;
    }
    if (payerId) {
      document.getElementById('payerDisplay').textContent = payerId;
    }

    // Try to get order details from API
    async function fetchOrderDetails() {
      if (!token) return;
      try {
        const res = await fetch('/check-order', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ orderId: token })
        });
        const data = await res.json();
        
        if (data.status === 'COMPLETED') {
          const amt = data.purchase_units?.[0]?.payments?.captures?.[0]?.amount;
          if (amt) {
            document.getElementById('amountDisplay').textContent = `${amt.currency_code} ${amt.value}`;
          }
          const payer = data.payer;
          if (payer) {
            document.getElementById('payerDisplay').textContent = 
              `${payer.name?.given_name || ''} ${payer.name?.surname || ''}`.trim() || payer.payer_id || '---';
          }
        }
      } catch(e) {
        // silent fallback
      }
    }
    
    fetchOrderDetails();
  </script>

  <style>
    .paypal-blue { background: #003087; }
    .paypal-blue:hover { background: #00256b; }
    .fade-in { animation: fadeIn 0.5s ease-in; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
  </style>
</body>
</html>
