<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>BOPIS — Payment Successful</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    .paypal-blue { background: #003087; }
    .paypal-blue:hover { background: #00256b; }
    .paypal-gold { background: #ffc439; color: #003087; }
    .paypal-gold:hover { background: #f3b82e; }
    .fade-in { animation: fadeIn 0.5s ease-in; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
  </style>
</head>
<body class="bg-gray-50 min-h-screen">
  <div class="max-w-lg mx-auto p-6">
    <a href="/" class="inline-flex items-center gap-1 text-sm text-gray-500 hover:text-gray-700 mb-6">← Back to Demo</a>

    <% if (error) { %>
      <div class="bg-amber-50 border border-amber-200 rounded-xl p-6 text-center">
        <p class="text-3xl mb-3">👀</p>
        <p class="font-semibold text-amber-800 mb-2">Payment Redirect Received</p>
        <p class="text-sm text-amber-600 mb-4"><%= error %></p>
        <a href="/" class="paypal-blue text-white font-semibold py-2.5 px-6 rounded-lg transition text-sm inline-block">Go to Home</a>
      </div>
    <% } else if (order) { %>
      <div class="bg-white rounded-xl shadow-sm p-6 mb-4 fade-in text-center">
        <div class="text-5xl mb-3">🏪</div>
        <h1 class="text-2xl font-bold text-green-600 mb-1">Payment Successful!</h1>
        <p class="text-sm text-gray-500 mb-6">Your BOPIS order has been paid for.</p>

        <div class="bg-purple-50 border border-purple-200 rounded-xl p-6 mb-6 inline-block w-full max-w-xs">
          <p class="text-[10px] text-gray-400 uppercase tracking-wide mb-1">🔑 Pickup Code</p>
          <p class="font-mono font-bold text-3xl tracking-[0.25em] text-purple-700"><%= order.pickupCode %></p>
          <p class="text-[10px] text-gray-400 mt-3 uppercase tracking-wide">🏪 Store</p>
          <p class="text-sm font-medium text-purple-800">BOPIS Demo Store</p>
          <p class="text-xs text-purple-600">Downtown San Jose</p>
          <p class="text-xs text-purple-600">123 PayPal Blvd, San Jose, CA 95131</p>
          <p class="text-xs text-gray-400 mt-4">Show this code at the store to collect your items</p>
        </div>

        <% if (order.items && order.items.length > 0) { %>
          <div class="text-left mb-6">
            <p class="text-xs text-gray-400 uppercase tracking-wide mb-2 font-medium">Items</p>
            <div class="divide-y divide-gray-100 border border-gray-100 rounded-lg overflow-hidden">
              <% order.items.forEach(function(item) { %>
                <div class="flex items-center justify-between px-4 py-3 text-sm">
                  <div class="flex items-center gap-2">
                    <span><%= item.image || '📦' %></span>
                    <span><%= item.name %></span>
                  </div>
                  <span class="text-gray-500">$<%= item.price || item.unit_amount?.value || '—' %></span>
                </div>
              <% }) %>
            </div>
          </div>
        <% } %>

        <div class="grid grid-cols-2 gap-3 text-left mb-6 text-sm bg-gray-50 rounded-lg p-4">
          <div>
            <p class="text-xs text-gray-400">Total Paid</p>
            <p class="font-semibold">$<%= order.total %></p>
          </div>
          <div>
            <p class="text-xs text-gray-400">Order Status</p>
            <p class="font-medium text-green-600">READY FOR PICKUP</p>
          </div>
          <div class="col-span-2">
            <p class="text-xs text-gray-400">PayPal Order ID</p>
            <p class="font-mono text-xs text-gray-600 break-all"><%= order.paypalOrderId %></p>
          </div>
          <div class="col-span-2">
            <p class="text-xs text-gray-400">Created At</p>
            <p class="text-xs text-gray-600"><%= new Date(order.createdAt).toLocaleString() %></p>
          </div>
        </div>

        <div class="flex flex-col gap-2">
          <a href="/" class="paypal-blue text-white font-semibold py-2.5 px-6 rounded-lg transition text-sm inline-block w-full text-center">🏪 New BOPIS Order</a>
          <a href="/" class="text-sm text-gray-500 hover:text-gray-700">← Back to Home</a>
        </div>
      </div>
    <% } %>
  </div>
</body>
</html>
